PROJECT_NAME           = "HFT Core"
PROJECT_BRIEF          = "Deterministic price-time priority matching engine"
PROJECT_NUMBER         = "0.1.0"
OUTPUT_DIRECTORY       = "@CMAKE_BINARY_DIR@/docs"
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"

INPUT                  = "@CMAKE_SOURCE_DIR@/README.md" \
                         "@CMAKE_SOURCE_DIR@/lib/hft_core_lib/hft_core.hpp" \
                         "@CMAKE_SOURCE_DIR@/lib/hft_render_lib/hft_render.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/main.cpp"
FILE_PATTERNS          = *.md *.hpp *.h *.cpp
RECURSIVE              = NO
EXCLUDE_PATTERNS       = */build/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = @HFT_DOXYGEN_WARN_AS_ERROR@

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = @HFT_DOXYGEN_HAVE_DOT@
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = svg
DOT_CLEANUP            = YES
